---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const { entries: achievements, cacheHint } = await getEmDashCollection("achievements", {
	orderBy: { published_at: "desc" }
});

Astro.cache.set(cacheHint);
---

<Base title="Prestasi" description="Daftar prestasi siswa dan sekolah">
	<section class="list-page">
		<h1>Prestasi</h1>
		<ul>
			{achievements.map((item) => (
				<li>
					<a href={`/achievements/${item.id}`}>{item.data.title}</a>
					{item.data.summary && <p>{item.data.summary}</p>}
				</li>
			))}
		</ul>
	</section>
</Base>
