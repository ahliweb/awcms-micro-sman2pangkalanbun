---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";

type ImageLike = {
	id: string;
	src?: string;
	alt?: string;
	width?: number;
	height?: number;
};

const { entries, cacheHint } = await getEmDashCollection("downloads", {
	orderBy: { published_at: "desc" },
});

Astro.cache.set(cacheHint);

const files = entries
	.map((entry) => {
		const data = entry.data as Record<string, unknown>;
		const resourceUrl = typeof data.resource_url === "string" ? data.resource_url : null;
		if (!resourceUrl) return null;

		const previewRaw = data.preview_image;
		const previewImage =
			typeof previewRaw === "object" && previewRaw !== null && "id" in previewRaw
				? (previewRaw as ImageLike)
				: null;

		return {
			id: entry.id,
			title: typeof data.title === "string" ? data.title : "Untitled file",
			description: typeof data.description === "string" ? data.description : null,
			category: typeof data.category === "string" ? data.category : null,
			publishedOn: data.published_on instanceof Date ? data.published_on : null,
			resourceUrl,
			previewImage,
		};
	})
	.filter((item): item is NonNullable<typeof item> => item !== null);

function formatDate(date: Date | null) {
	if (!date) return null;
	return date.toLocaleDateString("id-ID", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Base title="Files" description="Galeri dokumen PDF sekolah">
	<section class="files-hero">
		<p class="eyebrow">Document Center</p>
		<h1>Files PDF</h1>
		<p>
			Lihat dokumen resmi sekolah dalam tampilan galeri. Pilih pratinjau untuk
			membuka PDF di popup, atau gunakan tautan langsung untuk membuka tab baru.
		</p>
	</section>

	{
		files.length === 0 ? (
			<section class="files-empty">
				<h2>Belum ada file</h2>
				<p>Tambahkan entri di koleksi Downloads dan isi Resource URL PDF.</p>
			</section>
		) : (
			<>
				<section class="files-grid" aria-label="PDF gallery">
					{files.map((item) => (
						<article class="file-card">
							<button
								type="button"
								class="preview-button"
								data-open-pdf
								data-pdf-url={item.resourceUrl}
								data-pdf-title={item.title}
							>
								{item.previewImage ? (
									<Image image={item.previewImage} />
								) : (
									<div class="preview-fallback" aria-hidden="true">
										<span>PDF</span>
									</div>
								)}
							</button>
							<div class="file-meta">
								{item.category && <p class="file-category">{item.category}</p>}
								<h2>{item.title}</h2>
								{item.description && <p>{item.description}</p>}
								{formatDate(item.publishedOn) && (
									<p class="file-date">Dipublikasikan {formatDate(item.publishedOn)}</p>
								)}
								<div class="file-actions">
									<button
										type="button"
										class="btn-inline"
										data-open-pdf
										data-pdf-url={item.resourceUrl}
										data-pdf-title={item.title}
									>
										Preview
									</button>
									<a href={item.resourceUrl} target="_blank" rel="noopener noreferrer">Buka</a>
									<a href={item.resourceUrl} download>Unduh</a>
								</div>
							</div>
						</article>
					))}
				</section>

				<section class="files-list" aria-label="Daftar file">
					<h2>Daftar File</h2>
					<ul>
						{files.map((item) => (
							<li>
								<span>{item.title}</span>
								<a href={item.resourceUrl} target="_blank" rel="noopener noreferrer">Open</a>
							</li>
						))}
					</ul>
				</section>
			</>
		)
	}

	<div class="pdf-modal" data-pdf-modal hidden>
		<div class="pdf-overlay" data-close-pdf></div>
		<section class="pdf-dialog" role="dialog" aria-modal="true" aria-labelledby="pdf-title">
			<header>
				<h2 id="pdf-title">Preview PDF</h2>
				<button type="button" class="close-btn" data-close-pdf aria-label="Tutup preview">
					Close
				</button>
			</header>
			<iframe title="PDF viewer" data-pdf-frame loading="lazy"></iframe>
		</section>
	</div>

	<script is:inline>
		(() => {
			const modal = document.querySelector("[data-pdf-modal]");
			if (!(modal instanceof HTMLElement)) return;

			const frame = modal.querySelector("[data-pdf-frame]");
			const title = modal.querySelector("#pdf-title");

			const close = () => {
				modal.hidden = true;
				document.body.classList.remove("pdf-open");
				if (frame instanceof HTMLIFrameElement) frame.src = "";
			};

			document.querySelectorAll("[data-open-pdf]").forEach((trigger) => {
				trigger.addEventListener("click", () => {
					if (!(trigger instanceof HTMLElement)) return;
					const url = trigger.dataset.pdfUrl;
					const pdfTitle = trigger.dataset.pdfTitle;
					if (!url || !(frame instanceof HTMLIFrameElement)) return;

					frame.src = url;
					if (title && pdfTitle) title.textContent = `Preview: ${pdfTitle}`;
					modal.hidden = false;
					document.body.classList.add("pdf-open");
				});
			});

			modal.querySelectorAll("[data-close-pdf]").forEach((el) => {
				el.addEventListener("click", close);
			});

			document.addEventListener("keydown", (event) => {
				if (event.key === "Escape" && !modal.hidden) {
					close();
				}
			});
		})();
	</script>
</Base>

<style>
	.files-hero,
	.files-grid,
	.files-list,
	.files-empty {
		max-width: 1100px;
		margin: 0 auto;
		padding-inline: 1.25rem;
	}

	.files-hero {
		padding-top: 2rem;
		padding-bottom: 1.5rem;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--color-muted);
		margin: 0;
	}

	.files-hero h1 {
		margin: 0.35rem 0 0.7rem;
		font-size: clamp(1.8rem, 3vw, 2.5rem);
	}

	.files-hero p {
		max-width: 65ch;
		color: var(--color-muted);
	}

	.files-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.1rem;
		padding-bottom: 2rem;
	}

	.file-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.preview-button {
		border: 0;
		padding: 0;
		background: transparent;
		cursor: pointer;
	}

	.preview-button img,
	.preview-fallback {
		width: 100%;
		height: 190px;
		object-fit: cover;
		display: block;
	}

	.preview-fallback {
		display: grid;
		place-items: center;
		background: linear-gradient(135deg, #173b56, #245f88);
		color: #f4fbff;
		font-size: 1.1rem;
		font-weight: 700;
	}

	.file-meta {
		padding: 1rem;
		display: grid;
		gap: 0.5rem;
	}

	.file-meta h2 {
		margin: 0;
		font-size: 1.1rem;
	}

	.file-meta p {
		margin: 0;
		color: var(--color-muted);
	}

	.file-category {
		font-size: 0.76rem;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		font-weight: 700;
		color: var(--color-foreground);
	}

	.file-date {
		font-size: 0.88rem;
	}

	.file-actions {
		display: flex;
		gap: 0.8rem;
		align-items: center;
		font-size: 0.92rem;
	}

	.file-actions a,
	.btn-inline {
		color: var(--color-link);
		text-decoration: none;
		font-weight: 600;
		border: 0;
		background: transparent;
		padding: 0;
		cursor: pointer;
	}

	.file-actions a:hover,
	.btn-inline:hover {
		text-decoration: underline;
	}

	.files-list {
		padding-bottom: 3rem;
	}

	.files-list h2 {
		margin-top: 0;
	}

	.files-list ul {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid var(--color-border);
	}

	.files-list li {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.8rem 0;
		border-bottom: 1px solid var(--color-border);
	}

	.files-empty {
		padding-block: 3rem;
	}

	.files-empty h2 {
		margin-top: 0;
	}

	.pdf-modal {
		position: fixed;
		inset: 0;
		z-index: 70;
	}

	.pdf-overlay {
		position: absolute;
		inset: 0;
		background: rgb(2 6 23 / 78%);
	}

	.pdf-dialog {
		position: relative;
		margin: min(4vh, 1.5rem) auto;
		width: min(96vw, 980px);
		height: min(92vh, 820px);
		background: var(--color-background);
		border-radius: var(--radius-lg);
		overflow: hidden;
		border: 1px solid var(--color-border);
		display: grid;
		grid-template-rows: auto 1fr;
	}

	.pdf-dialog header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.75rem 1rem;
		border-bottom: 1px solid var(--color-border);
	}

	.pdf-dialog h2 {
		margin: 0;
		font-size: 1rem;
	}

	.close-btn {
		border: 1px solid var(--color-border);
		background: var(--color-surface);
		color: var(--color-foreground);
		padding: 0.35rem 0.7rem;
		border-radius: var(--radius-sm);
		cursor: pointer;
	}

	.pdf-dialog iframe {
		width: 100%;
		height: 100%;
		border: 0;
	}

	body.pdf-open {
		overflow: hidden;
	}

	@media (max-width: 640px) {
		.pdf-dialog {
			width: 100vw;
			height: 100vh;
			margin: 0;
			border-radius: 0;
		}

		.files-list li {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
