---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

const { entries: downloads, cacheHint } = await getEmDashCollection("downloads", {
	orderBy: { published_at: "desc" }
});

Astro.cache.set(cacheHint);
---

<Base title="Unduhan" description="Dokumen dan berkas unduhan sekolah">
	<section class="list-page">
		<h1>Unduhan</h1>
		<ul>
			{downloads.map((item) => (
				<li>
					<h2><a href={`/downloads/${item.id}`}>{item.data.title}</a></h2>
					{item.data.description && <p>{item.data.description}</p>}
				</li>
			))}
		</ul>
	</section>
</Base>
