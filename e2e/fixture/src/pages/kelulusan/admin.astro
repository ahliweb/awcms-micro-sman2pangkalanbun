---
const user = Astro.locals.user;
---

<html>
	<body>
		<h1>Kelulusan Admin</h1>
		{
			!user
				? <a href="/_emdash/admin/login?redirect=%2Fkelulusan%2Fadmin">Login</a>
				: <p id="admin-ready">Admin active</p>
		}

		<table id="student-table">
			<thead>
				<tr>
					<th>NISN</th>
					<th>Name</th>
					<th>File</th>
					<th>Opened</th>
					<th>Downloaded</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody id="rows"></tbody>
		</table>

		<dialog id="pdf-dialog">
			<button id="close-dialog" type="button">Tutup</button>
			<iframe id="pdf-frame" title="PDF"></iframe>
		</dialog>

		<script is:inline>
			const API_BASE = "/_emdash/api/plugins/kelulusan";
			const rowsEl = document.getElementById("rows");
			const dialog = document.getElementById("pdf-dialog");
			const frame = document.getElementById("pdf-frame");

			async function post(path, body) {
				const response = await fetch(`${API_BASE}/${path}`, {
					method: "POST",
					headers: {
						"Content-Type": "application/json",
						"X-EmDash-Request": "1",
					},
					credentials: "same-origin",
					body: JSON.stringify(body),
				});
				const payload = await response.json().catch(() => ({}));
				if (!response.ok) {
					throw new Error(payload?.error?.message || "Request failed");
				}
				if (payload && typeof payload === "object" && "success" in payload) {
					if (!payload.success) {
						throw new Error(payload?.error?.message || "Request failed");
					}
					return payload.data;
				}
				if (payload && typeof payload === "object" && "data" in payload) {
					return payload.data;
				}
				return payload;
			}

			function render(items) {
				rowsEl.innerHTML = "";
				for (const item of items) {
					const tr = document.createElement("tr");
					tr.innerHTML = `
						<td>${item.nisn}</td>
						<td>${item.name}</td>
						<td>${item.pdfFilename}</td>
						<td>${item.openedCount}</td>
						<td>${item.downloadedCount}</td>
						<td>
							<button data-action="open" data-nisn="${item.nisn}">Open</button>
							<button data-action="download" data-nisn="${item.nisn}">Download</button>
						</td>
					`;
					rowsEl.appendChild(tr);
				}
			}

			async function refresh() {
				const data = await post("students/list", { limit: 100 });
				render(data.items || []);
			}

			rowsEl.addEventListener("click", async (event) => {
				const target = event.target;
				if (!(target instanceof HTMLButtonElement)) return;
				const action = target.dataset.action;
				const nisn = target.dataset.nisn;
				if (!action || !nisn) return;

				const eventType = action === "download" ? "downloaded" : "opened";
				const result = await post("documents/access/admin", { nisn, eventType });

				if (action === "download") {
					window.open(result.pdfUrl, "_blank", "noopener");
				} else {
					frame.src = `${result.pdfUrl}#toolbar=1&navpanes=0`;
					dialog.showModal();
				}

				await refresh();
			});

			document.getElementById("close-dialog").addEventListener("click", () => {
				dialog.close();
				frame.src = "";
			});

			void refresh();
		</script>
	</body>
</html>
