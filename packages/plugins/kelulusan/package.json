{
	"name": "@emdash-cms/plugin-kelulusan",
	"private": true,
	"version": "0.0.1",
	"description": "Kelulusan plugin scaffold for NISN-gated graduation PDF access",
	"type": "module",
	"main": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./sandbox": "./src/sandbox-entry.ts"
	},
	"files": ["src"],
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
		"dev": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --watch",
		"test": "vitest run",
		"typecheck": "tsgo --noEmit"
	},
	"keywords": ["emdash", "cms", "plugin", "kelulusan", "nisn"],
	"author": "Matt Kane",
	"license": "MIT",
	"peerDependencies": {
		"emdash": "workspace:>=0.9.0"
	},
	"dependencies": {
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/emdash-cms/emdash.git",
		"directory": "packages/plugins/kelulusan"
	}
}
