{
	"name": "@emdash-cms/plugin-academic-calendar",
	"private": true,
	"version": "0.0.1",
	"description": "Academic calendar plugin foundation for EmDash",
	"type": "module",
	"main": "dist/index.mjs",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"types": "./dist/index.d.mts"
		},
		"./sandbox": "./dist/sandbox-entry.mjs"
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --clean",
		"dev": "tsdown src/index.ts src/sandbox-entry.ts --format esm --dts --watch",
		"test": "vitest run",
		"typecheck": "tsgo --noEmit"
	},
	"keywords": ["emdash", "cms", "plugin", "academic-calendar"],
	"author": "Matt Kane",
	"license": "MIT",
	"peerDependencies": {
		"emdash": "workspace:>=0.9.0"
	},
	"dependencies": {
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/emdash-cms/emdash.git",
		"directory": "packages/plugins/academic-calendar"
	}
}
